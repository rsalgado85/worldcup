{
  "expo": {
    "name": "Resuelve",
    "slug": "resuelve-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070B16"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.resuelve.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Resuelve necesita tu ubicacion para mostrarte conductores, rutas y servicios cercanos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A1F44"
      },
      "package": "com.resuelve.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Resuelve necesita acceder a tu ubicación para mostrarte conductores, rutas y servicios cercanos."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
